generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  PENDIENTE
  CONFIRMADO
  FINALIZADO
  CANCELADO
}

enum EquipmentType {
  AIRE_ACONDICIONADO
  HELADERA
  FREEZER
  OTRO
}

enum VisitReason {
  LIMPIEZA
  MANTENIMIENTO
  REPARACION
  OTRO
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  MERCADO_PAGO
  TARJETA
  OTRO
}

enum AttachmentType {
  FOTO
  VIDEO
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointmentsCreated Appointment[] @relation("AppointmentCreatedBy")
  sessions            Session[]
}

model Client {
  id           String   @id @default(uuid())
  fullName     String
  phone        String   @unique
  address      String
  neighborhood String?
  city         String   @default("Posadas")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments Appointment[]
  equipments   Equipment[]

  @@index([phone])
  @@index([fullName])
}

model Equipment {
  id        String        @id @default(uuid())
  clientId  String
  type      EquipmentType
  brand     String?
  model     String?
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([clientId])
  @@index([type])
}

model Appointment {
  id String @id @default(uuid())

  clientId    String
  equipmentId String?
  createdById String?

  date   DateTime
  time   String
  status AppointmentStatus @default(PENDIENTE)

  equipmentType      EquipmentType
  visitReason        VisitReason
  problemDescription String

  address      String
  neighborhood String?
  city         String  @default("Posadas")

  waitingFeeNotice Boolean @default(true)

  waitingFeeAmount Int @default(30000)

  finalPrice    Int?
  paymentMethod PaymentMethod?
  paid          Boolean        @default(false)

  technicianNotes    String?
  cancellationReason String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  finalizedAt DateTime?
  cancelledAt DateTime?

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  equipment   Equipment?   @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  createdBy   User?        @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  attachments Attachment[]

  @@index([clientId])
  @@index([equipmentId])
  @@index([status])
  @@index([date])
}

model Attachment {
  id            String         @id @default(uuid())
  appointmentId String
  type          AttachmentType
  url           String
  fileName      String?
  mimeType      String?
  size          Int?
  createdAt     DateTime       @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model Service {
  id                       String      @id @default(uuid())
  name                     String
  description              String?
  visitReason              VisitReason
  basePrice                Int?
  estimatedDurationMinutes Int?
  isActive                 Boolean     @default(true)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  @@index([isActive])
  @@index([visitReason])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}
